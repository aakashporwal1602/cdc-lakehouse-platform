{
  "suite_name": "payments_suite",
  "meta": {"table": "lakehouse.silver.payments"},
  "expectations": [
    {"expectation_type": "expect_column_values_to_be_unique",
     "kwargs": {"table": "lakehouse.silver.payments", "column": "payment_id"}},
    {"expectation_type": "expect_column_values_to_be_between",
     "kwargs": {"table": "lakehouse.silver.payments", "column": "amount",
                "min_value": 0, "max_value": 1000000}},
    {"expectation_type": "expect_column_values_to_be_in_set",
     "kwargs": {"table": "lakehouse.silver.payments", "column": "status",
                "value_set": ["authorized","captured","failed","refunded"]}}
  ]
}
