# ============================================================================
# CDC Lakehouse Platform - Environment Configuration
# Copy to `.env` and adjust. NEVER commit the populated .env file.
# ============================================================================

# --- Postgres (CDC source) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=commerce
POSTGRES_USER=cdc_admin
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_REPLICATION_SLOT=debezium_slot
POSTGRES_PUBLICATION=dbz_publication

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081
KAFKA_CONNECT_URL=http://kafka-connect:8083
CDC_TOPIC_PREFIX=commerce

# --- MinIO / S3 (Iceberg warehouse) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
ICEBERG_WAREHOUSE=s3a://lakehouse/warehouse

# --- Iceberg REST catalog ---
ICEBERG_CATALOG_URI=http://iceberg-rest:8181
ICEBERG_CATALOG_NAME=lakehouse

# --- Spark ---
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_CHECKPOINT_ROOT=s3a://lakehouse/_checkpoints
SPARK_MAX_OFFSETS_PER_TRIGGER=50000
SPARK_SHUFFLE_PARTITIONS=64

# --- Trino ---
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=analytics

# --- Observability ---
PROMETHEUS_PUSHGATEWAY=http://pushgateway:9091
LOG_LEVEL=INFO
LOG_FORMAT=json
ENVIRONMENT=local
